{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@content/*":    ["./src/content/*"],
      "@i18n/*":       ["./src/i18n/*"],
      "@layouts/*":    ["./src/layouts/*"],
      "@lib/*":        ["./src/lib/*"],
      "@styles/*":     ["./src/styles/*"]
    }
  }
}
