---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => data.lang === "el");
  return projects.map((project) => ({
    params: { slug: project.id.split("/")[1] },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, thumbnail, tags, year, location } = project.data;
---

<MainLayout title={`${title} | Kiriakouarch`} lang="el">
  <article class="px-6 py-24 md:py-32 bg-zinc-50">
    <div class="max-w-7xl mx-auto">
      <a
        href="/projects"
        class="inline-block text-sm text-zinc-500 hover:text-zinc-900 hover:underline transition-colors mb-8"
      >
        &larr; Όλα τα έργα
      </a>

      <Image
        src={thumbnail}
        alt={title}
        class="w-full h-[50vh] md:h-[70vh] object-cover"
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
      />

      <div class="mt-8">
        <h1 class="text-2xl md:text-3xl font-bold text-zinc-900">{title}</h1>
        <p class="text-base text-zinc-600 mt-2">{description}</p>

        {
          (location || year) && (
            <p class="text-sm text-zinc-400 mt-3">
              {[location, year].filter(Boolean).join(" · ")}
            </p>
          )
        }

        {
          tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <span class="text-xs px-3 py-1 bg-zinc-200 text-zinc-700 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        <div class="prose prose-zinc mt-12 max-w-3xl">
          <Content />
        </div>
      </div>
    </div>
  </article>
</MainLayout>
