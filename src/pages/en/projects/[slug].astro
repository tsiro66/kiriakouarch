---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import MainLayout from "../../../layouts/MainLayout.astro";
import { t, localizeProject } from "../../../i18n";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const localized = localizeProject(project.data, "en");
const gallery = [localized.thumbnail, ...(project.data.images || [])];
---

<MainLayout title={`${localized.title} | Kiriakouarch`} description={localized.description} lang="en">
  <article class="px-6 pt-12 md:pt-16 pb-24 md:pb-32 bg-zinc-50">
    <div class="max-w-7xl mx-auto">
      <a
        href="/en/projects"
        class="inline-block text-sm text-zinc-600 hover:text-zinc-900 hover:underline transition-colors mb-8"
      >
        {t("en", "projects", "backToAll")}
      </a>

      <div class="mt-8">
        <h1 class="text-2xl md:text-3xl font-bold text-zinc-900">{localized.title}</h1>
        <p class="text-base text-zinc-600 mt-2">{localized.description}</p>

        {
          (localized.location || localized.year) && (
            <p class="text-sm text-zinc-500 mt-3">
              {[localized.location, localized.year].filter(Boolean).join(" · ")}
            </p>
          )
        }

        {
          localized.tags && localized.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {localized.tags.map((tag) => (
                <span class="text-xs px-3 py-1 bg-zinc-200 text-zinc-700 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        {
          localized.body && (
            <div class="prose prose-zinc mt-12 max-w-3xl">
              <p>{localized.body}</p>
            </div>
          )
        }
      </div>

      <div class="mt-16 flex flex-col gap-4">
        {gallery.map((img) => (
          <div class="bg-zinc-200">
            <Image
              src={img}
              alt={localized.title}
              class="w-full h-[50vh] md:h-[70vh] object-cover"
              widths={[640, 1024, 1440, 1920]}
              sizes="100vw"
            />
          </div>
        ))}
      </div>
    </div>
  </article>
</MainLayout>