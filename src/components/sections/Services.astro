---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);

import enServices from "../../i18n/en/services.json";
import elServices from "../../i18n/el/services.json";
const items = locale === "el" ? elServices.items : enServices.items;
---

<section class="px-6 py-24 md:py-32 bg-zinc-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-6">
      {t(locale, "services", "title")}
    </h1>
    <p class="text-lg md:text-xl text-zinc-600 max-w-3xl leading-relaxed mb-16">
      {t(locale, "services", "intro")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {items.map((item) => (
        <div class="border-t border-zinc-200 pt-6">
          <h2 class="text-xl font-bold text-zinc-900 mb-2">{item.name}</h2>
          <p class="text-base text-zinc-600 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
