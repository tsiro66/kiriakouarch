---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);

import enServices from "../../i18n/en/services.json";
import elServices from "../../i18n/el/services.json";
const items = locale === "el" ? elServices.items : enServices.items;
const ctaLink = locale === "el" ? "/contact" : "/en/contact";
---

<section class="px-6 pt-12 md:pt-16 pb-24 md:pb-32 bg-zinc-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-6">
      {t(locale, "services", "title")}
    </h1>
    <p class="text-lg md:text-xl text-zinc-600 max-w-3xl leading-relaxed mb-16">
      {t(locale, "services", "intro")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {items.map((item, i) => (
        <div class="border-t border-zinc-200 pt-6">
          <span class="text-sm text-zinc-500 font-mono">0{i + 1}</span>
          <h2 class="text-xl font-bold text-zinc-900 mt-3 mb-2">{item.name}</h2>
          <p class="text-base text-zinc-600 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-32 md:mt-40 pt-16 border-t border-zinc-200">
      <div class="max-w-2xl">
        <p class="text-xl md:text-2xl text-zinc-600 leading-relaxed mb-10">
          {locale === "el"
            ? "Έχετε ένα έργο στο μυαλό σας; Ας το συζητήσουμε."
            : "Have a project in mind? Let’s talk about it."}
        </p>
        <a
          href={ctaLink}
          class="inline-block text-lg font-semibold text-zinc-900 border-b-2 border-zinc-900 pb-1 hover:text-zinc-500 hover:border-zinc-500 transition-colors duration-300"
        >
          {locale === "el" ? "Επικοινωνήστε μαζί μας" : "Get in touch"}
        </a>
      </div>
    </div>
  </div>
</section>
