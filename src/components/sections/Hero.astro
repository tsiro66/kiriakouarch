---
import { Image } from "astro:assets";
import { tArray, t, getLocaleFromUrl } from "../../i18n";
import heroImg from "../../assets/hero-img.jpg";

const locale = getLocaleFromUrl(Astro.url);
const tags = tArray(locale, "home", "tags");
const alt = t(locale, "home", "heroAlt");
---

<section class="px-6 pt-8 pb-0 bg-zinc-50">
  <div class="flex flex-wrap gap-3 mb-10">
    {tags.map((tag) => (
      <span class="rounded-full border border-zinc-900 px-4 py-2 text-sm md:text-base text-zinc-900">
        {tag}
      </span>
    ))}
  </div>

  <div class="max-w-7xl mx-auto">
    <Image
      src={heroImg}
      alt={alt}
      class="w-full h-[50vh] md:h-[75vh] object-cover"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
    />
  </div>

  <h1 class="max-w-7xl mx-auto mt-8 text-3xl md:text-6xl font-bold text-zinc-900">
    {t(locale, "home", "heroTitle")}
  </h1>
</section>
