---
import { Image } from "astro:assets";

interface Props {
  title: string;
  slug: string;
  description: string;
  thumbnail: ImageMetadata;
  tags?: string[];
  year?: number;
  location?: string;
  lang: string;
}

const { title, slug, description, thumbnail, tags, year, location, lang } =
  Astro.props;
const href = lang === "el" ? `/projects/${slug}` : `/en/projects/${slug}`;
---

<a href={href} class="group block">
  <div class="overflow-hidden">
    <Image
      src={thumbnail}
      alt={title}
      class="w-full h-64 md:h-80 object-cover transition-transform duration-500 group-hover:scale-105"
      widths={[400, 640, 800]}
      sizes="(max-width: 768px) 100vw, 50vw"
    />
  </div>
  <div class="mt-4">
    <h3 class="text-lg font-bold text-zinc-900 group-hover:text-zinc-600 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-zinc-500 mt-1">{description}</p>
    {
      (location || year) && (
        <p class="text-xs text-zinc-400 mt-2">
          {[location, year].filter(Boolean).join(" · ")}
        </p>
      )
    }
  </div>
</a>
