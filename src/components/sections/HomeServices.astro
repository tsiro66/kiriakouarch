---
import { t, getLocaleFromUrl, getSection } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
const services = getSection(locale, "services");
const items = services.items;
const servicesLink = locale === "el" ? "/services" : "/en/services";
---

<section class="px-6 py-24 md:py-32 bg-zinc-900 text-white">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16">
      <h2 class="text-3xl md:text-4xl font-bold">
        {t(locale, "services", "title")}
      </h2>
      <a href={servicesLink} class="text-sm tracking-widest uppercase text-zinc-400 hover:text-white hover:underline transition-colors">
        {t(locale, "home", "learnMoreServices")} &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2">
      {items.map((item, i) => (
        <div class={`py-6 flex items-center gap-6 border-b border-zinc-700${i % 2 === 0 ? " md:pr-10 md:border-r" : " md:pl-10"}`}>
          <span class="text-sm text-zinc-400 font-mono">0{i + 1}</span>
          <h3 class="text-lg font-bold">{item.name}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
