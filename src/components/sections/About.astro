---
import { Image } from "astro:assets";
import { t, getLocaleFromUrl } from "../../i18n";
import heroImg from "../../assets/hero-img.jpg";

import enAbout from "../../i18n/en/about.json";
import elAbout from "../../i18n/el/about.json";

const locale = getLocaleFromUrl(Astro.url);
const ctaLink = locale === "el" ? "/projects" : "/en/projects";
const milestones = locale === "el" ? elAbout.milestones : enAbout.milestones;
---

<section class="px-6 pt-12 md:pt-16 pb-24 md:pb-32 bg-zinc-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-6">
      {t(locale, "about", "title")}
    </h1>
    <p class="text-lg md:text-xl text-zinc-600 max-w-3xl leading-relaxed mb-16">
      {t(locale, "about", "intro")}
    </p>

    <div class="mb-24 bg-zinc-200">
      <Image
        src={heroImg}
        alt={t(locale, "about", "heroAlt")}
        class="w-full h-[400px] md:h-[560px] object-cover"
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-24">
      <div>
        <h2 class="text-xl font-bold text-zinc-900 mb-1">
          {t(locale, "about", "philosophyTitle")}
        </h2>
        <span class="text-sm tracking-widest uppercase text-zinc-500">
          {t(locale, "about", "philosophyRole")}
        </span>
        <p class="text-base text-zinc-600 leading-relaxed mt-4">
          {t(locale, "about", "philosophyText")}
        </p>
      </div>
      <div>
        <h2 class="text-xl font-bold text-zinc-900 mb-1">
          {t(locale, "about", "experienceTitle")}
        </h2>
        <span class="text-sm tracking-widest uppercase text-zinc-500">
          {t(locale, "about", "experienceRole")}
        </span>
        <p class="text-base text-zinc-600 leading-relaxed mt-4">
          {t(locale, "about", "experienceText")}
        </p>
      </div>
    </div>

    <div class="mb-16">
      <span class="text-sm tracking-widest uppercase text-zinc-500">
        {t(locale, "about", "milestonesTitle")}
      </span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-6 mt-8">
        {milestones.map((m) => (
          <div class="flex gap-6 border-t border-zinc-200 pt-4">
            <span class="text-sm font-bold text-zinc-900 shrink-0">{m.year}</span>
            <p class="text-sm text-zinc-600">{m.text}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16">
      <a href={ctaLink} class="text-lg font-bold text-zinc-900 hover:underline">
        {t(locale, "about", "ctaText")} &rarr;
      </a>
    </div>
  </div>
</section>
