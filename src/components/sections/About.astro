---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
const ctaLink = locale === "el" ? "/projects" : "/en/projects";
---

<section class="px-6 py-24 md:py-32 bg-zinc-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-6">
      {t(locale, "about", "title")}
    </h1>
    <p class="text-lg md:text-xl text-zinc-600 max-w-3xl leading-relaxed mb-16">
      {t(locale, "about", "intro")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="text-xl font-bold text-zinc-900 mb-3">
          {t(locale, "about", "philosophyTitle")}
        </h2>
        <p class="text-base text-zinc-600 leading-relaxed">
          {t(locale, "about", "philosophyText")}
        </p>
      </div>
      <div>
        <h2 class="text-xl font-bold text-zinc-900 mb-3">
          {t(locale, "about", "experienceTitle")}
        </h2>
        <p class="text-base text-zinc-600 leading-relaxed">
          {t(locale, "about", "experienceText")}
        </p>
      </div>
    </div>

    <div class="mt-16">
      <a href={ctaLink} class="text-lg font-bold text-zinc-900 hover:underline">
        {t(locale, "about", "ctaText")} &rarr;
      </a>
    </div>
  </div>
</section>
