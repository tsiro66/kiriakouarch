---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
---

<section class="px-6 pt-12 md:pt-16 pb-24 md:pb-32 bg-zinc-50 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-6">
      {t(locale, "contact", "title")}
    </h1>
    <p class="text-lg md:text-xl text-zinc-600 max-w-3xl leading-relaxed mb-16">
      {t(locale, "contact", "intro")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="flex flex-col gap-8">
        <div>
          <span class="text-sm text-zinc-500">{t(locale, "contact", "addressLabel")}</span>
          <p class="text-base text-zinc-900 mt-1">{t(locale, "contact", "address")}</p>
        </div>
        <div>
          <span class="text-sm text-zinc-500">{t(locale, "contact", "phoneLabel")}</span>
          <p class="text-base mt-1">
            <a href={`tel:${t(locale, "contact", "phoneIntl")}`} class="text-zinc-900 hover:underline">{t(locale, "contact", "phone")}</a>
          </p>
        </div>
        <div>
          <span class="text-sm text-zinc-500">{t(locale, "contact", "emailLabel")}</span>
          <p class="text-base mt-1">
            <a href={`mailto:${t(locale, "contact", "email")}`} class="text-zinc-900 hover:underline">{t(locale, "contact", "email")}</a>
          </p>
        </div>
        <div>
          <span class="text-sm text-zinc-500">{t(locale, "contact", "hoursLabel")}</span>
          <p class="text-base text-zinc-900 mt-1">{t(locale, "contact", "hours")}</p>
        </div>
      </div>
    </div>
  </div>
</section>
