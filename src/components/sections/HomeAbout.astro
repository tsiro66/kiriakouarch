---
import { Image } from "astro:assets";
import { t, getLocaleFromUrl } from "../../i18n";
import aboutImg from "../../assets/projects/project-02.jpg";

const locale = getLocaleFromUrl(Astro.url);
const aboutLink = locale === "el" ? "/about" : "/en/about";
---

<section class="px-6 py-24 md:py-32">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
    <div class="overflow-hidden bg-zinc-200">
      <Image
        src={aboutImg}
        alt={t(locale, "about", "title")}
        class="w-full h-[400px] md:h-[560px] object-cover"
        widths={[400, 640, 800]}
        sizes="(max-width: 768px) 100vw, 50vw"
      />
    </div>

    <div>
      <h2 class="text-sm tracking-widest uppercase text-zinc-500 font-normal">
        {t(locale, "about", "title")}
      </h2>
      <p class="text-lg md:text-xl text-zinc-600 leading-relaxed mt-4 mb-8">
        {t(locale, "about", "intro")}
      </p>

      <div class="space-y-8">
        <div>
          <h3 class="text-base font-bold text-zinc-900 mb-1">{t(locale, "about", "philosophyTitle")}</h3>
          <p class="text-sm text-zinc-600 leading-relaxed">{t(locale, "about", "philosophyText")}</p>
        </div>
        <div>
          <h3 class="text-base font-bold text-zinc-900 mb-1">{t(locale, "about", "experienceTitle")}</h3>
          <p class="text-sm text-zinc-600 leading-relaxed">{t(locale, "about", "experienceText")}</p>
        </div>
      </div>

      <div class="mt-10 flex gap-8">
        <a href={aboutLink} class="text-sm tracking-widest uppercase text-zinc-600 hover:text-zinc-900 hover:underline transition-colors">
          {t(locale, "home", "learnMoreAbout")} &rarr;
        </a>

      </div>
    </div>
  </div>
</section>
