---
import { getCollection } from "astro:content";
import { t, getLocaleFromUrl, localizeProject } from "../../i18n";
import ProjectCard from "./ProjectCard.astro";

const locale = getLocaleFromUrl(Astro.url);
const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const allTags = Array.from(
  new Set(projects.flatMap((p) => (locale === "el" ? p.data.tagsEl : p.data.tagsEn) || []))
).sort();
---

<section class="px-6 pt-12 md:pt-16 pb-24 md:pb-32 bg-zinc-50">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 md:mb-14">
      <h1 class="text-3xl md:text-4xl font-bold text-zinc-900">
        {t(locale, "projects", "title")}
      </h1>
      {
        allTags.length > 0 && (
          <div class="flex flex-wrap gap-2 md:gap-3 mt-4" id="project-filters">
            <button
              type="button"
              class="filter-btn text-xs md:text-sm px-4 md:px-6 py-1.5 md:py-2.5 rounded-full bg-zinc-900 text-white cursor-pointer transition-colors"
              data-filter="all"
              aria-pressed="true"
            >
              {t(locale, "projects", "filterAll")}
            </button>
            {allTags.map((tag) => (
              <button
                type="button"
              class="filter-btn text-xs md:text-sm px-4 md:px-6 py-1.5 md:py-2.5 rounded-full bg-transparent border border-zinc-900 text-zinc-900 cursor-pointer hover:bg-zinc-900 hover:text-white transition-colors"
              data-filter={tag}
              aria-pressed="false"
              >
                {tag}
              </button>
            ))}
          </div>
        )
      }
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16" id="projects-grid">
      {
        projects.map((project) => {
          const loc = localizeProject(project.data, locale);
          return (
          <div data-tags={JSON.stringify(loc.tags || [])}>
            <ProjectCard
              title={loc.title}
              slug={project.id}
              description={loc.description}
              thumbnail={loc.thumbnail}
              tags={loc.tags}
              year={loc.year}
              location={loc.location}
              lang={locale}
            />
          </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  let controller: AbortController | undefined;

  function initFilters() {
    controller?.abort();
    controller = new AbortController();

    const filterBtns = document.querySelectorAll<HTMLButtonElement>("#project-filters .filter-btn");
    const projectItems = document.querySelectorAll<HTMLElement>("#projects-grid > [data-tags]");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter;
        if (!filter) return;

        filterBtns.forEach((b) => {
          b.setAttribute("aria-pressed", "false");
          b.classList.remove("bg-zinc-900", "text-white");
          b.classList.add("bg-transparent", "border", "border-zinc-900", "text-zinc-900", "hover:bg-zinc-900", "hover:text-white");
        });
        btn.setAttribute("aria-pressed", "true");
        btn.classList.add("bg-zinc-900", "text-white");
        btn.classList.remove("bg-transparent", "border", "border-zinc-900", "text-zinc-900", "hover:bg-zinc-900", "hover:text-white");

        projectItems.forEach((item) => {
          const tags = JSON.parse(item.dataset.tags || "[]");
          if (filter === "all" || tags.includes(filter)) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        });
      }, { signal: controller!.signal });
    });
  }

  initFilters();
  document.addEventListener("astro:after-swap", initFilters);
</script>