---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
---

<section class="px-6 py-24 md:py-32">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-start">
    <div>
      <span class="text-sm tracking-widest uppercase text-zinc-500">
        {locale === "el" ? "Πάτρα · Από το 1975" : "Patras · Since 1975"}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mt-3 leading-tight">
        {t(locale, "home", "introTitle")}
      </h2>
    </div>
    <div class="flex items-start">
      <p class="text-lg text-zinc-600 leading-relaxed">
        {t(locale, "home", "introText")}
      </p>
    </div>
  </div>
</section>
