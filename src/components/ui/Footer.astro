---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
const prefix = locale === "el" ? "" : `/${locale}`;
const year = new Date().getFullYear();
---

<footer id="site-footer" class="fixed bottom-0 left-0 w-full bg-zinc-900">
  <div class="px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <div>
        <span class="text-5xl font-bold text-zinc-50">K</span>
      </div>

      <div class="flex flex-col gap-3 text-sm text-zinc-400">
        <a href={`${prefix}/about`} class="hover:text-zinc-50">{t(locale, "nav", "about")}</a>
        <a href={`${prefix}/projects`} class="hover:text-zinc-50">{t(locale, "nav", "projects")}</a>
        <a href={`${prefix}/services`} class="hover:text-zinc-50">{t(locale, "nav", "services")}</a>
        <a href={`${prefix}/contact`} class="hover:text-zinc-50">{t(locale, "nav", "contact")}</a>
      </div>

      <div class="flex flex-col gap-6 text-sm">
        <div>
          <span class="text-zinc-500">{t(locale, "footer", "addressLabel")}</span>
          <p class="text-zinc-400 mt-1">{t(locale, "footer", "address")}</p>
        </div>
        <div>
          <span class="text-zinc-500">{t(locale, "footer", "phoneLabel")}</span>
          <p class="mt-1"><a href="tel:+302610321146" class="text-zinc-400 hover:text-zinc-50">{t(locale, "footer", "phone")}</a></p>
        </div>
        <div>
          <span class="text-zinc-500">{t(locale, "footer", "emailLabel")}</span>
          <p class="mt-1"><a href={`mailto:${t(locale, "footer", "email")}`} class="text-zinc-400 hover:text-zinc-50">{t(locale, "footer", "email")}</a></p>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-zinc-700 flex flex-col md:flex-row justify-between gap-4 text-xs text-zinc-500">
      <span>&copy; {year} Kiriakouarch. {t(locale, "footer", "rights")}.</span>
    </div>
  </div>
</footer>

<script>
  function setFooterMargin() {
    const footer = document.getElementById("site-footer")!;
    const wrapper = document.getElementById("content-wrapper")!;
    wrapper.style.marginBottom = `${footer.offsetHeight}px`;
  }
  setFooterMargin();
  window.addEventListener("resize", setFooterMargin);
</script>
