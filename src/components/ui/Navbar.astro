---
import { t, getLocaleFromUrl } from "../../i18n";

const locale = getLocaleFromUrl(Astro.url);
const prefix = locale === "el" ? "" : `/${locale}`;
const otherLocale = locale === "el" ? "en" : "el";
const otherPrefix = otherLocale === "el" ? "" : `/${otherLocale}`;
const currentPath = Astro.url.pathname.replace(/^\/(en|el)/, "");
const is404 = /^\/404/.test(currentPath);

const pathSegment = is404 ? "home" : (currentPath.replace(/^\//, "").split("/")[0] || "home");
const pageKey = ["about", "projects", "services", "contact"].includes(pathSegment) ? pathSegment : "home";
const pageTitle = t(locale, "nav", pageKey);
const localeSwitchPath = is404 ? "/" : currentPath;
---

<nav id="site-nav" aria-label={t(locale, "nav", "menu")} class="fixed top-0 left-0 w-full z-50 mix-blend-difference">
  <div class="relative mx-auto px-6 flex items-center justify-between h-22">
    
    <div class="flex gap-2 text-sm tracking-widest" role="group" aria-label="Language">
      <span class={locale === "el" ? "font-bold text-white" : "text-white/50"}>
        {locale === "el" ? <span aria-current="true" class="inline-flex items-center min-h-12 px-1 font-bold text-white">GR</span> : <a href={`${otherPrefix}${localeSwitchPath}`} hreflang="el" class="inline-flex items-center min-h-12 px-1 hover:text-white/80">GR</a>}
      </span>
      <span class="text-white/30 inline-flex items-center" aria-hidden="true">|</span>
      <span class={locale === "en" ? "font-bold text-white" : "text-white/50"}>
        {locale === "en" ? <span aria-current="true" class="inline-flex items-center min-h-12 px-1 font-bold text-white">EN</span> : <a href={`${otherPrefix}${localeSwitchPath}`} hreflang="en" class="inline-flex items-center min-h-12 px-1 hover:text-white/80">EN</a>}
      </span>
    </div>

    <a href={`${prefix}/`} class="absolute left-1/2 -translate-x-1/2 inline-flex items-center min-h-12">
      <img src="/logo.png" alt="Kiriakouarch" class="h-20 md:h-25 w-auto invert" width="80" height="100" />
    </a>


    <button
      id="menu-toggle"
      type="button"
      aria-label={t(locale, "nav", "menu")}
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex flex-col justify-center items-center gap-1.5 w-12 h-12 cursor-pointer"
    >
      <span class="block w-10 h-0.5 bg-white transition-transform duration-300 origin-center" id="line-1"></span>
      <span class="block w-10 h-0.5 bg-white transition-transform duration-300 origin-center" id="line-2"></span>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  role="dialog"
  aria-label={t(locale, "nav", "menu")}
  class="fixed inset-0 z-40 hidden flex-col items-center justify-center gap-8 bg-zinc-50"
>
  <a href={`${prefix}/`} class="inline-flex items-center min-h-12 text-2xl md:text-5xl text-zinc-900 hover:text-zinc-600 hover:underline">{t(locale, "nav", "home")}</a>
  <a href={`${prefix}/about`} class="inline-flex items-center min-h-12 text-2xl md:text-5xl text-zinc-900 hover:text-zinc-600 hover:underline">{t(locale, "nav", "about")}</a>
  <a href={`${prefix}/projects`} class="inline-flex items-center min-h-12 text-2xl md:text-5xl text-zinc-900 hover:text-zinc-600 hover:underline">{t(locale, "nav", "projects")}</a>
  <a href={`${prefix}/services`} class="inline-flex items-center min-h-12 text-2xl md:text-5xl text-zinc-900 hover:text-zinc-600 hover:underline">{t(locale, "nav", "services")}</a>
  <a href={`${prefix}/contact`} class="inline-flex items-center min-h-12 text-2xl md:text-5xl text-zinc-900 hover:text-zinc-600 hover:underline">{t(locale, "nav", "contact")}</a>
</div>

<script>
  function setupMenu() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const line1 = document.getElementById("line-1");
    const line2 = document.getElementById("line-2");
    if (!toggle || !menu || !line1 || !line2) return;

    menu.classList.add("hidden");
    menu.classList.remove("flex");
    line1.style.transform = "";
    line2.style.transform = "";
    toggle.setAttribute("aria-expanded", "false");

    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      const isOpen = !open;
      menu.classList.toggle("flex", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));

      if (isOpen) {
        line1.style.transform = "translateY(4px) rotate(45deg)";
        line2.style.transform = "translateY(-4px) rotate(-45deg)";
      } else {
        line1.style.transform = "";
        line2.style.transform = "";
      }
    });
  }

  document.addEventListener("astro:after-swap", setupMenu);
  setupMenu();
</script>
