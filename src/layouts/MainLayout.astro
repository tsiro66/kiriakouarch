---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/ui/Navbar.astro";
import Footer from "../components/ui/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  lang?: string;
}

const { title, lang = "en" } = Astro.props;
const hasHero = Astro.slots.has("hero");
---

<!doctype html>
<html lang={lang} data-has-hero={hasHero ? "true" : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    <Font cssVariable="--font-roboto-mono" />
  </head>
  <body>
    <Navbar />
    {hasHero && <slot name="hero" />}
    <div id="content-wrapper" class:list={["relative z-10", { "pointer-events-none": hasHero }]}>
      {hasHero && <div id="hero-spacer" class="h-screen"></div>}
      <main class:list={["bg-zinc-50", { "pt-22": !hasHero, "pointer-events-auto": hasHero }]}>
        <slot />
      </main>
    </div>
    <Footer />

    <script>
      let controller;

      function initLayout() {
        if (controller) controller.abort();
        controller = new AbortController();

        const hero = document.getElementById("hero");
        const spacer = document.getElementById("hero-spacer");
        const footer = document.getElementById("site-footer");
        const wrapper = document.getElementById("content-wrapper");
        const hasHero = !!hero;

        function setFooterMargin() {
          if (footer && wrapper) {
            wrapper.style.marginBottom = `${footer.offsetHeight}px`;
          }
        }

        setFooterMargin();

        if (hasHero) {
          function setHeroSpacer() {
            if (spacer) spacer.style.height = `${hero.offsetHeight}px`;
          }

          function updateHeroZ() {
            if (!footer || !wrapper) return;
            const scrollBottom = window.scrollY + window.innerHeight;
            const footerRevealPoint = wrapper.offsetTop + wrapper.offsetHeight;
            hero.style.zIndex = scrollBottom > footerRevealPoint ? "-1" : "";
          }

          setHeroSpacer();
          updateHeroZ();
          window.addEventListener("scroll", updateHeroZ, { signal: controller.signal });
        }

        window.addEventListener("resize", () => {
          setFooterMargin();
          if (hasHero && spacer) spacer.style.height = `${hero.offsetHeight}px`;
        }, { signal: controller.signal });
      }

      initLayout();
      document.addEventListener("astro:after-swap", initLayout);
    </script>
  </body>
</html>
